# ── MongoDB ────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/neuralbase
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/neuralbase
MONGODB_URI=mongodb://localhost:27017/neuralbase

# ── AI Providers ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── RAG Settings ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.3
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ── Security ───────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
